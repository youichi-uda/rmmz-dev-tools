{
  "compilerOptions": {
    "target": "ES2020",
    "module": "none",
    "outDir": "js/plugins",
    "rootDir": "ts/plugins",
    "removeComments": false,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "typeRoots": [],
    "lib": ["ES2020"]
  },
  "include": [
    "ts/**/*.ts",
    "ts/typings/**/*.d.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
